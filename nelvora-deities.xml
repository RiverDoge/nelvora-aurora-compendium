	<element name="Caeplithias" type="Deity" source="Aurora: Nelvora" id="ID_NELVORA_DEITY_CAEPLITHIAS">
		<description>
			<p class="flavor">Goddess of Hope</p>
		</description>
		<setters>
			<set name="setting">NELVORA</set>
			<set name="alignment">LG</set>
			<set name="domains">Tempest, Morning, Hope</set>
			<set name="symbol">Dragon curled to form a frame around a blazing ornate eye.</set>
			<set name="gender">female</set>
		</setters>
		<sheet>
			<description>Silver Dragon of the Sunrise, Goddess of Hope, and Trusted Friend of the Blazing Jewel.</description>
		</sheet>
	</element>
