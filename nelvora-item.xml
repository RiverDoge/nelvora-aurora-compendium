	<!-- light armor -->
	<element name="Chiton of Caeplithias" type="Magic Item" source="Aurora: Nelvora" id="ID_NELVORA_CHITON_OF_CAEPLITHIAS">
		<supports>ID_INTERNAL_ARMOR_GROUP_LIGHT</supports>
		<description>
			<p>Elegant chiton imbued with the power of Caeplithias. When under the Wet effect, gains increased durability.</p>
			<p class="indent">While wearing this chiton, your base AC becomes 15 + your Dex Modifier. While wet this is increased to a base AC of 16 + your dex modifier.</p>
		</description>
		<setters>
			<set name="category">Wondrous Items</set>
			<set name="cost" currency="gp">250</set>
			<set name="weight" lb="2">2 lb.</set>
			<set name="slot">body</set>
			<set name="armor">Light</set>
			<set name="armorClass">15 + Dex modifier</set>
			<set name="proficiency">ID_PROFICIENCY_ARMOR_PROFICIENCY_PADDED</set>
			<set name="attunement">true</set>
			<set name="rarity">Legendary</set>
		</setters>
		<rules>
			<stat name="ac:armored:armor" value="15" />
		</rules>
	</element>
